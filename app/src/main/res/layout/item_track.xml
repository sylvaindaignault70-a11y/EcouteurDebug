<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="#080810"
    android:gravity="center_vertical">

    <TextView android:id="@+id/tvTrackNum"
        android:layout_width="28dp" android:layout_height="wrap_content"
        android:textColor="#475569" android:textSize="11sp"/>

    <TextView android:id="@+id/tvTrackName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="#e2e8f0"
        android:textSize="13sp" android:singleLine="true" android:ellipsize="end"
        android:layout_marginEnd="8dp"/>

    <Button android:id="@+id/btnPlay"
        android:layout_width="44dp" android:layout_height="36dp"
        android:text="▶" android:backgroundTint="#7c3aed" android:textColor="#ffffff"
        android:textSize="12sp" android:padding="0dp"/>

</LinearLayout>
