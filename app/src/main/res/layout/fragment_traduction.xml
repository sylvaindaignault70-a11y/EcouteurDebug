<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810"
    android:clipToPadding="false"
    android:paddingBottom="160dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 TRADUCTION LIVE"
            android:textColor="#7c3aed"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="MOI" android:textColor="#94a3b8" android:textSize="11sp" android:minWidth="48dp"/>
            <Spinner android:id="@+id/spinTradMoi" android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:background="#0f0f1a"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AUTRE" android:textColor="#94a3b8" android:textSize="11sp" android:minWidth="48dp"/>
            <Spinner android:id="@+id/spinTradOther" android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:background="#0f0f1a"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnMoi"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="🎤 MOI" android:backgroundTint="#7c3aed" android:textColor="#ffffff"
                android:layout_marginEnd="6dp"
                android:maxLines="1"/>
            <Button android:id="@+id/btnAutre"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="👂 L'AUTRE" android:backgroundTint="#06b6d4" android:textColor="#ffffff"
                android:layout_marginEnd="6dp"
                android:maxLines="1"/>
            <Button android:id="@+id/btnStop"
                android:layout_width="wrap_content" android:layout_height="52dp"
                android:text="⏹" android:backgroundTint="#1a1a2e" android:textColor="#ef4444"
                android:maxLines="1"/>
        </LinearLayout>

        <TextView android:id="@+id/tvTradStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Appuie MOI ou L'AUTRE" android:textColor="#64748b"
            android:textSize="12sp" android:gravity="center" android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#0f0f1a" android:padding="10dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🎤 MOI" android:textColor="#64748b" android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvOriginal"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#e2e8f0" android:textSize="14sp" android:minHeight="60dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#0f0f1a" android:padding="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🔊 TRADUCTION" android:textColor="#64748b" android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvTradResult"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="—" android:textColor="#06b6d4" android:textSize="14sp" android:minHeight="60dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button android:id="@+id/btnRec"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="⏺ Rec" android:backgroundTint="#ef4444" android:textColor="#ffffff"
            android:gravity="start|center_vertical" android:paddingStart="16dp"
            android:layout_marginTop="12dp"
                android:maxLines="1"/>

        <Button android:id="@+id/btnSaveText"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="💾 Sauvegarder" android:backgroundTint="#1a1a2e" android:textColor="#06b6d4"
            android:gravity="start|center_vertical" android:paddingStart="16dp"
            android:layout_marginTop="8dp"
                android:maxLines="1"/>

    </LinearLayout>
</ScrollView>
