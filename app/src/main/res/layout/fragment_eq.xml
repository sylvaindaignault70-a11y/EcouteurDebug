<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080810"
    android:paddingBottom="80dp"
    android:clipToPadding="false">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎚️ ÉGALISEUR"
        android:textColor="#7c3aed"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:paddingStart="8dp">
        <LinearLayout android:id="@+id/presetContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <Button android:id="@+id/btnResetEQ"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="↺ Flat" android:backgroundTint="#1a1a2e" android:textColor="#e2e8f0"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <LinearLayout android:id="@+id/bandsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <Button android:id="@+id/btnSaveEQ"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:text="💾 Sauvegarder" android:backgroundTint="#1a1a2e" android:textColor="#10b981"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginTop="8dp"/>

    <TextView android:id="@+id/tvEQStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lance la musique d'abord"
        android:textColor="#64748b"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp"/>

</LinearLayout>
